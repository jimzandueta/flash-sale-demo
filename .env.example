AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

REDIS_HOST_PORT=6379
DYNAMODB_HOST_PORT=8000
LOCALSTACK_HOST_PORT=4566
API_HOST_PORT=3000
FRONTEND_HOST_PORT=5173

REDIS_URL=redis://redis:6379
SQS_ENDPOINT=http://localstack:4566
DYNAMO_ENDPOINT=http://dynamodb-local:8000

DEFAULT_RESERVATION_TTL_SECONDS=180
RESERVATIONS_TABLE=flash-sale-reservations-local
RESERVATION_EVENTS_QUEUE_URL=http://localstack:4566/000000000000/dev-reservation-events
PURCHASE_EVENTS_QUEUE_URL=http://localstack:4566/000000000000/dev-purchase-events
EXPIRY_EVENTS_QUEUE_URL=http://localstack:4566/000000000000/dev-expiry-events

LOCAL_WORKER_MODE=manual
WORKER_POLL_WAIT_SECONDS=5
WORKER_POLL_MAX_MESSAGES=10
WORKER_HEARTBEAT_INTERVAL_MS=5000
EXPIRY_SWEEP_INTERVAL_MS=10000

STRESS_BASE_URL=http://localhost:3000
